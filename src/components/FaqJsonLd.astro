---
import type { Faq } from '../data/faqs';

interface Props {
  items: Faq[];
}

const { items } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
