---
import { locations } from '../data/locations';

const areas = locations.map((l) => ({ name: l.city, href: `/service-areas/${l.slug}/` }));
---

<section id="service-areas" class="bg-navy py-16 md:py-20" aria-labelledby="service-areas-heading">
  <div class="reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-black uppercase tracking-[0.25em] text-yellow">Where We Work</p>
      <h2 id="service-areas-heading" class="mt-2 text-3xl font-black uppercase tracking-tight text-white sm:text-4xl">
        Serving Marion County &amp; Surrounding Areas
      </h2>
      <p class="mt-4 text-base font-medium text-slate-300">
        Based in Ocala · ~20-mile service radius · Under-45-minute typical response
      </p>
    </div>

    <!-- Mobile: clean pin list -->
    <ul class="mt-8 grid grid-cols-2 gap-x-4 gap-y-3 sm:hidden">
      {areas.map((area) => (
        <li>
          <a href={area.href} class="flex items-center gap-2 rounded-md px-1 py-1 hover:text-yellow">
            <svg class="h-3.5 w-3.5 shrink-0 text-yellow" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.003 3.5-4.697 3.5-8.327a8 8 0 10-16 0c0 3.63 1.556 6.324 3.5 8.327a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3.5 3.5 0 100-7 3.5 3.5 0 000 7z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold text-slate-200">{area.name}</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop: pill buttons -->
    <ul class="mt-10 hidden grid-cols-3 gap-3 sm:grid md:grid-cols-4">
      {areas.map((area) => (
        <li>
          <a
            href={area.href}
            class="flex items-center justify-center rounded-full border border-white/20 px-4 py-2.5 text-sm font-semibold text-white transition hover:border-yellow/60 hover:bg-white/10 hover:text-yellow"
          >
            {area.name}
          </a>
        </li>
      ))}
    </ul>

    <p class="mt-10 text-center text-sm text-slate-400">
      Not sure if you're in our area?
      <a href="/contact/" class="font-bold text-yellow hover:underline">Ask us →</a>
    </p>
  </div>
</section>
