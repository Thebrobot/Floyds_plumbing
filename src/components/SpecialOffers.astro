---
import { siteConfig } from '../site.config';

const offers = [
  {
    badge: 'Save $50',
    title: '$50 Off Water Heater Replacement',
    description: 'New installation or replacement on any tank or tankless water heater. Must mention offer when booking.',
    icon: 'flame'
  },
  {
    badge: '$150 Value',
    title: 'Free Backflow Test with Service Plan',
    description: 'Sign up for our annual maintenance plan and receive a complimentary backflow inspection.',
    icon: 'shield'
  },
  {
    badge: '10% Off',
    title: '10% Off Whole-Home Repipe',
    description: 'Upgrade your plumbing with a full repipe and save 10% on labor. Valid for new residential customers.',
    icon: 'pipe'
  },
  {
    badge: 'Veterans & Seniors',
    title: '10% Off Labor for Vets & 65+',
    description: 'Thank-you discount for active military, veterans, and seniors. Applied automatically, no code needed.',
    icon: 'heart'
  }
];
---

<section class="bg-page-muted py-16 md:py-20" aria-labelledby="offers-heading">
  <div class="reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">Savings</p>
      <h2 id="offers-heading" class="mt-2 text-3xl font-black uppercase tracking-tight text-navy sm:text-4xl">
        Current Special Offers
      </h2>
      <p class="mt-4 text-base font-medium text-slate-600">
        Call to confirm availability and redeem your savings.
      </p>
    </div>

    <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {offers.map((offer) => (
        <li class="group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-md transition hover:-translate-y-1 hover:shadow-xl motion-reduce:transform-none motion-reduce:hover:translate-y-0">
          <div class="relative flex h-36 items-center justify-center overflow-hidden bg-gradient-to-br from-brand/90 to-navy">
            <div class="absolute -top-6 -right-6 h-28 w-28 rounded-full bg-white/10" aria-hidden="true"></div>
            <div class="absolute -bottom-8 -left-8 h-32 w-32 rounded-full bg-yellow/15" aria-hidden="true"></div>
            <span class="absolute left-3 top-3 rounded-full bg-yellow px-3 py-1 text-[0.65rem] font-black uppercase tracking-widest text-white shadow-md">
              {offer.badge}
            </span>
            <svg class="relative h-16 w-16 text-white/90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              {offer.icon === 'flame' && (
                <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" />
              )}
              {offer.icon === 'shield' && (
                <>
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="m9 12 2 2 4-4" />
                </>
              )}
              {offer.icon === 'pipe' && (
                <>
                  <path d="M4 12h4M16 12h4M10 6v12M14 6v12" />
                  <rect x="8" y="6" width="8" height="12" rx="1" />
                </>
              )}
              {offer.icon === 'heart' && (
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
              )}
            </svg>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-lg font-black uppercase tracking-tight text-navy">{offer.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{offer.description}</p>
            <a
              href={`tel:${siteConfig.phoneTel}`}
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-red-600 hover:text-red-700 hover:underline"
            >
              <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call to Claim
            </a>
          </div>
        </li>
      ))}
    </ul>

    <p class="mt-8 text-center text-xs text-slate-500">
      *Offers cannot be combined. Limit one per household. Valid through end of current year.
    </p>
  </div>
</section>
