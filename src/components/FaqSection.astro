---
import { faqs } from '../data/faqs';

interface Props {
  /** How many FAQs to show (defaults to all). */
  limit?: number;
  heading?: string;
  eyebrow?: string;
  /** Show "View all FAQs" CTA. */
  showViewAll?: boolean;
}

const { limit, heading = 'Frequently Asked Questions', eyebrow = 'Answers', showViewAll = true } = Astro.props;

const items = typeof limit === 'number' ? faqs.slice(0, limit) : faqs;
---

<section class="bg-page-muted py-16 md:py-24" aria-labelledby="faq-heading">
  <div class="reveal mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">{eyebrow}</p>
      <h2 id="faq-heading" class="mt-2 text-3xl font-black uppercase tracking-tight text-navy sm:text-4xl">{heading}</h2>
    </div>
    <ul class="mt-10 space-y-3">
      {items.map((faq, i) => (
        <li>
          <details class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition open:shadow-md" {...(i === 0 ? { open: true } : {})}>
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-left">
              <h3 class="text-base font-black text-navy sm:text-lg">{faq.question}</h3>
              <svg class="mt-1 h-5 w-5 shrink-0 text-brand transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600 sm:text-base">{faq.answer}</p>
          </details>
        </li>
      ))}
    </ul>
    {showViewAll && typeof limit === 'number' && faqs.length > limit && (
      <div class="mt-8 text-center">
        <a
          href="/faq/"
          class="inline-flex items-center justify-center rounded-full border-2 border-brand px-8 py-3 text-sm font-black uppercase tracking-wide text-brand transition hover:bg-brand hover:text-white"
        >
          View all FAQs →
        </a>
      </div>
    )}
  </div>
</section>
