---
import { siteConfig } from '../site.config';
---

<!-- Mobile: full-width split action bar -->
<div class="flex w-full shadow-[0_4px_16px_rgba(0,0,0,0.25)] md:hidden">
  <a
    href="/contact/"
    class="flex flex-1 items-center justify-center gap-2 bg-navy py-5 text-sm font-black uppercase leading-none tracking-wider text-white"
  >
    <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
    </svg>
    Book Now
  </a>
  <div class="w-px bg-white/20"></div>
  <a
    href={`tel:${siteConfig.phoneTel}`}
    class="flex flex-1 items-center justify-center gap-2 bg-red-600 py-5 text-sm font-black uppercase leading-none tracking-wider text-white"
  >
    <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    Call {siteConfig.phoneDisplay}
  </a>
</div>

<!-- Desktop: compact info bar -->
<div class="hidden w-full bg-navy text-white md:block">
  <a
    href={`tel:${siteConfig.phoneTel}`}
    class="mx-auto flex max-w-6xl items-center justify-center gap-2.5 px-6 py-2 lg:px-8"
  >
    <svg class="h-4 w-4 shrink-0 text-yellow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    <span class="text-sm font-semibold text-white">
      24/7 Emergency Service
      <span class="mx-1.5 text-white/30">|</span>
      <span class="font-black text-red-400">{siteConfig.phoneDisplay}</span>
    </span>
  </a>
</div>
