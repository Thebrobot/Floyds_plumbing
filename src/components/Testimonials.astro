---
import { siteConfig } from '../site.config';

/**
 * NOTE: Replace these with real Google/Facebook reviews before launch.
 * Paraphrased review content here is for layout purposes only.
 */
const reviews = [
  {
    name: 'Sarah M.',
    location: 'Ocala, FL',
    service: 'Pipe leak repair',
    text: "Floyd's Plumbing came out the same afternoon I called. They diagnosed a slab leak, walked me through options, and rerouted the line overhead. Clean worksite, fair price, and the paperwork made my insurance claim painless."
  },
  {
    name: 'James R.',
    location: 'Belleview, FL',
    service: 'Whole-home repipe',
    text: "Had them repipe our entire house in PEX. The crew was punctual, respectful of our floors, and finished a day early. Water pressure has been incredible since. Top-notch work from a family business you can trust."
  },
  {
    name: 'Linda K.',
    location: 'Dunnellon, FL',
    service: 'Emergency drain clearing',
    text: 'Called on a Sunday morning with a sewer backup. They answered right away and had a technician at my door within the hour. Honest, fast, reasonably priced. Not sure what more you could ask for.'
  },
  {
    name: 'Mike D.',
    location: 'Silver Springs Shores, FL',
    service: 'Water heater replacement',
    text: 'Old water heater finally quit. They showed up with a new one on the truck, swapped it in two hours, and took the old one. Price was exactly what they quoted on the phone.'
  },
  {
    name: 'Cheryl T.',
    location: 'Summerfield, FL',
    service: 'Toilet + faucet upgrades',
    text: "I'm a 78-year-old widow and these folks treated me like family. Explained everything, no pressure, great work. The senior discount was a nice touch. This is who I'll call from now on."
  },
  {
    name: 'Patrick L.',
    location: 'Ocala, FL',
    service: 'Tankless water heater install',
    text: "Did homework on tankless brands and they steered me to the right model for our family size and gas meter. Install was clean, venting looks factory, and they came back to check temps a week later."
  }
];
---

<section class="bg-page py-16 md:py-24" aria-labelledby="testimonials-heading">
  <div class="reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">Reviews</p>
      <h2 id="testimonials-heading" class="mt-2 text-3xl font-black uppercase tracking-tight text-navy sm:text-4xl">
        What Your Neighbors Say
      </h2>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 shadow-sm">
        <div class="flex gap-0.5" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => (
            <svg class="h-4 w-4 text-amber-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))}
        </div>
        <span class="text-sm font-black text-navy">{siteConfig.rating.value} / 5</span>
        <span class="text-xs font-bold uppercase tracking-widest text-slate-500">({siteConfig.rating.count}+ Google reviews)</span>
      </div>
    </div>

    <ul class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {reviews.map((review) => (
        <li class="card-service flex flex-col">
          <div class="flex gap-0.5 mb-4" role="img" aria-label="5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-5 w-5 text-amber-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          <p class="text-[0.65rem] font-black uppercase tracking-widest text-brand">{review.service}</p>
          <blockquote class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">
            "{review.text}"
          </blockquote>
          <footer class="mt-4 border-t border-slate-100 pt-4">
            <p class="text-sm font-black text-navy">{review.name}</p>
            <p class="text-xs text-slate-500">{review.location}</p>
          </footer>
        </li>
      ))}
    </ul>

    <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a
        href={siteConfig.googleBusinessUrl}
        class="inline-flex min-w-[14rem] items-center justify-center rounded-full bg-brand px-8 py-3.5 text-sm font-black uppercase tracking-wide text-white shadow-lg ring-2 ring-brand/20 transition hover:bg-brand-dark hover:ring-brand-dark/30"
        rel="noopener noreferrer"
        target="_blank"
      >
        Leave us a review
      </a>
      <a
        href={siteConfig.googleBusinessUrl}
        class="inline-flex items-center justify-center rounded-full border-2 border-slate-300 bg-white px-6 py-3 text-sm font-black uppercase tracking-wide text-navy transition hover:border-brand hover:text-brand"
        rel="noopener noreferrer"
        target="_blank"
      >
        Read more reviews
      </a>
    </div>
  </div>
</section>
