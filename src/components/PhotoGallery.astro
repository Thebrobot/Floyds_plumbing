---
const photos = [
  { src: '/images/floyds-service-van.webp', alt: "Floyd's Plumbing service van on site", span: 'md:col-span-2 md:row-span-2' },
  { src: '/images/pipes-detail.webp', alt: 'Clean copper and PEX manifold work', span: '' },
  { src: '/images/plumbing-work.webp', alt: 'Plumbing installation in progress', span: '' },
  { src: '/images/hero-team.webp', alt: "Floyd's Plumbing crew at a job site", span: 'md:col-span-2' }
];
---

<section class="bg-page py-16 md:py-24" aria-labelledby="gallery-heading">
  <div class="reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">Our Work</p>
      <h2 id="gallery-heading" class="mt-2 text-3xl font-black uppercase tracking-tight text-navy sm:text-4xl">
        Clean Installs, Tidy Job Sites
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-slate-600">
        We take pride in our craft. Here's what that looks like in the field.
      </p>
    </div>

    <div class="mt-12 grid gap-3 sm:grid-cols-2 md:grid-cols-4 md:grid-rows-2">
      {photos.map((photo) => (
        <figure class:list={[
          'group relative overflow-hidden rounded-2xl shadow-md ring-1 ring-slate-200/60',
          photo.span
        ]}>
          <img
            src={photo.src}
            alt={photo.alt}
            class="aspect-[4/3] h-full w-full object-cover transition duration-500 group-hover:scale-[1.04] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
            loading="lazy"
            decoding="async"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-navy/50 via-transparent to-transparent opacity-70 transition group-hover:opacity-90" aria-hidden="true" />
        </figure>
      ))}
    </div>
  </div>
</section>
