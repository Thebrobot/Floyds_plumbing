---
import { siteConfig } from '../site.config';

const currentYear = new Date().getFullYear();
const yearsInBusiness = currentYear - siteConfig.foundingYear;

const stats = [
  { value: yearsInBusiness, suffix: '+', label: 'Years in Business', decimals: 0 },
  { value: siteConfig.rating.value, suffix: '★', label: 'Google Rating', decimals: 1 },
  { value: siteConfig.rating.count, suffix: '+', label: 'Reviews', decimals: 0 },
  { value: 24, suffix: '/7', label: 'Emergency Service', decimals: 0 }
];
---

<section class="reveal relative overflow-hidden bg-hero pb-14 pt-10 md:pb-20 md:pt-14" aria-label="Company stats">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <ul class="grid grid-cols-2 gap-6 sm:grid-cols-4 sm:gap-4">
      {stats.map((s) => (
        <li class="text-center">
          <p class="flex items-baseline justify-center gap-0.5 font-black leading-none text-brand">
            <span
              class="text-4xl sm:text-5xl"
              data-count-target={s.value}
              data-count-duration="1400"
              data-count-decimals={s.decimals}
            >0</span>
            <span class="text-2xl sm:text-3xl">{s.suffix}</span>
          </p>
          <p class="mt-2 text-xs font-black uppercase tracking-[0.15em] text-navy sm:text-sm">{s.label}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
