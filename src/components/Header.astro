---
import { siteConfig } from '../site.config';
import { mainServices, subServices } from '../data/services';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const p = currentPath.replace(/\/$/, '') || '/';

const navActive = (href: string) => {
  const h = href.replace(/\/$/, '') || '/';
  if (h === '/') return p === '/';
  return p === h || p.startsWith(h + '/');
};

const linkClass = (href: string) =>
  navActive(href)
    ? 'text-brand font-bold'
    : 'text-charcoal font-semibold hover:text-brand';

const navLinkBase =
  'text-xs font-bold uppercase tracking-wide transition sm:text-[0.8125rem] sm:tracking-[0.06em]';
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-0 bg-transparent shadow-none"
>
  <div class="mx-auto w-full max-w-7xl px-3 pt-3.5 pb-3 sm:px-5 sm:pt-7 sm:pb-3 md:pt-8">
    <div
      class="header-main flex w-full items-center gap-2 overflow-visible rounded-full border border-slate-200/90 bg-white px-3 py-2.5 shadow-md sm:gap-3 sm:px-4 sm:py-3 md:gap-4 md:px-5 lg:px-6"
    >
    <!-- Logo -->
    <a
      href="/"
      aria-label={`${siteConfig.businessName} - Home`}
      class="flex shrink-0 items-center rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
    >
      <img
        src={siteConfig.logoPath}
        alt={siteConfig.businessName}
        width="938"
        height="375"
        class="header-logo h-11 w-auto max-w-[200px] object-contain object-left sm:h-12 sm:max-w-[240px] md:max-w-[260px]"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop nav -->
    <nav
      class="hidden min-w-0 flex-1 items-center justify-center gap-4 md:flex lg:gap-6 xl:gap-7"
      aria-label="Primary"
    >
      <a href="/" class={`${navLinkBase} ${linkClass('/')}`}>Home</a>

      <!-- Services dropdown -->
      <div class="relative" id="services-nav-wrap">
        <button
          type="button"
          id="services-nav-btn"
          class:list={[
            'flex items-center gap-0.5',
            navLinkBase,
            navActive('/services') ? 'text-brand font-bold' : 'text-charcoal font-semibold hover:text-brand'
          ]}
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="services-dropdown"
        >
          Services
          <svg class="h-3.5 w-3.5 shrink-0 transition-transform" id="services-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          id="services-dropdown"
          class="absolute left-1/2 top-full mt-2 w-[min(28rem,90vw)] -translate-x-1/2 rounded-2xl border border-slate-200 bg-white p-4 shadow-xl"
          hidden
        >
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <p class="text-[0.65rem] font-black uppercase tracking-widest text-slate-400">Main</p>
              <ul class="mt-2 space-y-0.5">
                {mainServices.map((s) => (
                  <li>
                    <a
                      href={`/services/${s.slug}/`}
                      class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-navy hover:bg-page-muted hover:text-brand"
                    >
                      {s.navTitle ?? s.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
            <div>
              <p class="text-[0.65rem] font-black uppercase tracking-widest text-slate-400">Specialty</p>
              <ul class="mt-2 space-y-0.5">
                {subServices.map((s) => (
                  <li>
                    <a
                      href={`/services/${s.slug}/`}
                      class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-navy hover:bg-page-muted hover:text-brand"
                    >
                      {s.navTitle ?? s.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="mt-3 border-t border-slate-100 pt-3">
            <a
              href="/services/"
              class="block rounded-lg px-2 py-1.5 text-center text-sm font-black text-brand hover:bg-page-muted"
            >
              View All Services →
            </a>
          </div>
        </div>
      </div>

      <a href="/service-areas/" class={`${navLinkBase} ${linkClass('/service-areas')}`}>Service Areas</a>
      <a href="/about/" class={`${navLinkBase} ${linkClass('/about')}`}>About</a>
      <a href="/faq/" class={`${navLinkBase} ${linkClass('/faq')}`}>FAQ</a>
      <a href="/contact/" class={`${navLinkBase} ${linkClass('/contact')}`}>Contact</a>
    </nav>

    <!-- Desktop CTA + mobile trigger -->
    <div class="ml-auto flex shrink-0 items-center gap-2 sm:gap-2.5">
      <a
        href={`tel:${siteConfig.phoneTel}`}
        class="hidden rounded-full bg-red-600 px-4 py-2.5 text-xs font-bold uppercase tracking-wide text-white shadow-sm transition hover:bg-red-700 md:inline-flex xl:px-5 xl:text-[0.8125rem]"
      >
        Call {siteConfig.phoneDisplay}
      </a>
      <a
        href="/contact/"
        class="hidden rounded-full bg-navy px-4 py-2.5 text-xs font-bold uppercase tracking-[0.08em] text-white shadow-sm transition hover:bg-charcoal-dark md:inline-flex xl:px-5 xl:text-[0.8125rem]"
      >
        Book Now
      </a>
      <button
        type="button"
        class="mobile-nav-open-trigger inline-flex items-center justify-center rounded-full border border-slate-300 bg-slate-50 p-2.5 text-navy hover:bg-slate-100 md:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
      >
        <span class="sr-only">Open menu</span>
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="mobile-nav-panel"
    class="fixed inset-0 z-[100] flex translate-x-full flex-col bg-white transition-transform duration-300 ease-out md:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Site menu"
    hidden
  >
    <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
      <a href="/" aria-label="Home">
        <img
          src={siteConfig.logoPath}
          alt={siteConfig.businessName}
          width="938"
          height="375"
          class="h-10 w-auto max-w-[180px] object-contain object-left"
          loading="eager"
          decoding="async"
        />
      </a>
      <button
        type="button"
        id="mobile-nav-close"
        class="rounded-full border border-slate-200 p-2 text-navy hover:bg-slate-50"
        aria-label="Close menu"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-width="2" d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
    <nav class="flex flex-1 flex-col gap-1 overflow-y-auto px-6 py-6" aria-label="Mobile primary">
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/">Home</a>
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/services/">All Services</a>
      <div class="border-l-2 border-brand/20 pl-4">
        {mainServices.map((s) => (
          <a class="mobile-nav-link block rounded-lg px-3 py-2 text-sm font-semibold text-slate-600 hover:bg-page-muted hover:text-brand" href={`/services/${s.slug}/`}>{s.navTitle ?? s.title}</a>
        ))}
      </div>
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/service-areas/">Service Areas</a>
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/about/">About</a>
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/financing/">Financing</a>
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/faq/">FAQ</a>
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/blog/">Blog</a>
      <a class="mobile-nav-link rounded-lg px-3 py-3 text-lg font-bold text-charcoal hover:bg-page-muted hover:text-brand" href="/contact/">Contact</a>
      <div class="mt-6 flex flex-col gap-3">
        <a
          class="mobile-nav-link inline-flex w-full items-center justify-center gap-2 rounded-full bg-red-600 px-8 py-4 text-base font-black text-white shadow-lg"
          href={`tel:${siteConfig.phoneTel}`}
        >
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {siteConfig.phoneDisplay}
        </a>
        <a
          class="mobile-nav-link inline-flex w-full items-center justify-center gap-2 rounded-full bg-navy px-8 py-4 text-base font-black uppercase tracking-wide text-white shadow-lg"
          href="/contact/"
        >
          Book Now
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  function setupMobileNav() {
    const openBtns = document.querySelectorAll('.mobile-nav-open-trigger');
    const closeBtn = document.getElementById('mobile-nav-close');
    const panel = document.getElementById('mobile-nav-panel');
    if (!openBtns.length || !closeBtn || !panel) return;

    const links = panel.querySelectorAll('.mobile-nav-link');

    function setExpanded(expanded: boolean) {
      openBtns.forEach(function (b) {
        b.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      });
    }

    function openMenu() {
      panel.hidden = false;
      void (panel as HTMLElement).offsetWidth;
      requestAnimationFrame(function () {
        panel.classList.remove('translate-x-full');
      });
      setExpanded(true);
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      panel.classList.add('translate-x-full');
      setExpanded(false);
      document.body.style.overflow = '';
      window.setTimeout(function () {
        if (panel.classList.contains('translate-x-full')) panel.hidden = true;
      }, 320);
    }

    openBtns.forEach(function (btn) {
      btn.addEventListener('click', openMenu);
    });
    closeBtn.addEventListener('click', closeMenu);
    links.forEach(function (a) {
      a.addEventListener('click', closeMenu);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && openBtns[0] && openBtns[0].getAttribute('aria-expanded') === 'true') closeMenu();
    });
  }

  function setupServicesDropdown() {
    const btn = document.getElementById('services-nav-btn');
    const dropdown = document.getElementById('services-dropdown');
    const chevron = document.getElementById('services-chevron');
    if (!btn || !dropdown) return;

    function open() {
      dropdown.hidden = false;
      btn!.setAttribute('aria-expanded', 'true');
      chevron?.classList.add('rotate-180');
    }

    function close() {
      dropdown.hidden = true;
      btn!.setAttribute('aria-expanded', 'false');
      chevron?.classList.remove('rotate-180');
    }

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      dropdown.hidden ? open() : close();
    });

    document.addEventListener('click', function (e) {
      if (!dropdown.hidden && !dropdown.contains(e.target as Node) && !btn.contains(e.target as Node)) {
        close();
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !dropdown.hidden) close();
    });
  }

  setupMobileNav();
  setupServicesDropdown();
</script>
