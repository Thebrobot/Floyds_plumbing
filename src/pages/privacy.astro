---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbJsonLd from '../components/BreadcrumbJsonLd.astro';

const title = "Privacy Policy | Floyd's Plumbing LLC";
const description =
  "How Floyd's Plumbing LLC collects, uses, shares, and protects personal information when you use our Ocala plumbing services or visit our website.";
---

<BaseLayout {title} {description}>
  <div class="relative border-b border-slate-200/80 bg-hero">
    <div class="bg-ripple pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
      <nav class="text-sm font-semibold text-brand-dark" aria-label="Breadcrumb">
        <ol class="flex flex-wrap gap-2">
          <li><a class="underline decoration-brand/30 underline-offset-4 hover:text-brand" href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="font-bold text-navy">Privacy Policy</li>
        </ol>
      </nav>
      <h1 class="font-display mt-6 text-4xl uppercase text-navy sm:text-5xl">Privacy Policy</h1>
      <p class="mt-4 text-lg font-semibold text-slate-700">Effective Date: April 30, 2026</p>
    </div>
  </div>

  <article class="bg-page py-14">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-10 text-base leading-relaxed text-slate-700">
        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">Introduction</h2>
          <p>
            Floyd's Plumbing LLC ("Floyd's Plumbing," "we," "us," or "our") is a licensed plumbing contractor located in
            Ocala, Florida. We are committed to protecting the privacy of our customers, website visitors, and business
            contacts. This Privacy Policy explains how we collect, use, disclose, and protect your personal information
            when you contact us, use our services, or visit our website.
          </p>
          <p>
            By using our services or providing us with your personal information, you agree to the practices described in
            this Privacy Policy.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">1. Information We Collect</h2>
          <h3 class="text-lg font-bold text-navy">Information You Provide Directly</h3>
          <ul class="list-disc space-y-2 pl-5">
            <li>Name, address, phone number, and email address</li>
            <li>Service address and property information</li>
            <li>Payment and billing information (processed through secure third-party payment processors)</li>
            <li>Details about your plumbing issue, service request, or project</li>
            <li>Communications you send us via phone, text, email, or online forms</li>
          </ul>
          <h3 class="mt-6 text-lg font-bold text-navy">Information Collected Automatically</h3>
          <ul class="list-disc space-y-2 pl-5">
            <li>IP address and browser type when visiting our website</li>
            <li>Pages visited, time spent, and referring URLs</li>
            <li>Device type and operating system</li>
          </ul>
          <h3 class="mt-6 text-lg font-bold text-navy">Information from Third Parties</h3>
          <ul class="list-disc space-y-2 pl-5">
            <li>Information provided by referral partners or scheduling platforms</li>
            <li>Reviews or ratings submitted on platforms such as Google, Yelp, or Facebook</li>
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">2. How We Use Your Information</h2>
          <p>We use the information we collect to:</p>
          <ul class="list-disc space-y-2 pl-5">
            <li>Schedule, dispatch, and perform plumbing services</li>
            <li>Communicate with you about appointments, estimates, and service updates</li>
            <li>Process payments and maintain billing records</li>
            <li>Respond to inquiries, complaints, or warranty requests</li>
            <li>Comply with applicable laws and licensing requirements</li>
            <li>Improve our services and customer experience</li>
            <li>Send appointment reminders or follow-up messages (you may opt out at any time)</li>
            <li>Maintain records required by Florida law or regulatory bodies</li>
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">3. How We Share Your Information</h2>
          <p>
            We do not sell, rent, or trade your personal information. We may share your information only in the following
            circumstances:
          </p>
          <ul class="list-disc space-y-3 pl-5">
            <li>
              <strong class="text-navy">Service Providers:</strong> With vendors, subcontractors, or software platforms
              that help us deliver services or operate our business (e.g., scheduling software, payment processors,
              SMS/communication tools), who are contractually bound to protect your information.
            </li>
            <li>
              <strong class="text-navy">Legal Requirements:</strong> When required by law, court order, or government
              authority, or to protect the rights, property, or safety of Floyd's Plumbing, our customers, or others.
            </li>
            <li>
              <strong class="text-navy">Business Transfers:</strong> In the event of a merger, acquisition, or sale of
              business assets, your information may be transferred as part of that transaction.
            </li>
            <li>
              <strong class="text-navy">With Your Consent:</strong> For any other purpose with your explicit consent.
            </li>
          </ul>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">4. Data Security</h2>
          <p>
            We implement reasonable administrative, technical, and physical safeguards to protect your personal
            information from unauthorized access, use, or disclosure. However, no method of transmission over the internet
            or electronic storage is 100% secure, and we cannot guarantee absolute security.
          </p>
          <p>
            We retain your information only as long as necessary to fulfill the purposes outlined in this policy or as
            required by law.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">
            5. Text Messaging &amp; Communications
          </h2>
          <p>
            If you provide your mobile phone number to Floyd's Plumbing through any channel — including our website,
            contact forms, or by phone — you consent to receive SMS text messages from us related to appointment
            confirmations, technician dispatch notifications, service estimates, billing reminders, and general customer
            service communications.
          </p>
          <p>Message and data rates may apply. Message frequency will vary based on your service activity.</p>
          <p>
            To opt out of SMS messages at any time, reply STOP to any message you receive from us. To request help, reply
            HELP or contact us directly at <a class="font-semibold text-brand underline underline-offset-2 hover:text-brand-dark" href="tel:+13523046404">(352) 304-6404</a>
            or <a class="font-semibold text-brand underline underline-offset-2 hover:text-brand-dark" href="mailto:kenny@floydtheplumber.com">kenny@floydtheplumber.com</a>.
          </p>
          <p>
            We do not sell, rent, share, or disclose your mobile phone number or SMS opt-in information to third parties
            or affiliates for marketing purposes.
          </p>
          <p>
            For full details on how SMS communications are handled, including message types and frequency, please review
            our Terms of Service at [insert Terms of Service URL].
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">6. Your Privacy Rights</h2>
          <p>As a Florida resident, you have certain rights regarding your personal information, including:</p>
          <ul class="list-disc space-y-2 pl-5">
            <li>The right to request access to the personal information we hold about you</li>
            <li>The right to request correction of inaccurate information</li>
            <li>The right to request deletion of your personal information, subject to legal or contractual obligations</li>
            <li>The right to opt out of marketing communications at any time</li>
          </ul>
          <p>
            To exercise any of these rights, contact us using the information in Section 9 below. We will respond to
            verifiable requests within a reasonable timeframe.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">
            7. Cookies &amp; Website Tracking
          </h2>
          <p>
            Our website may use cookies and similar tracking technologies to improve user experience and analyze website
            traffic. You can control cookie preferences through your browser settings. Disabling cookies may affect certain
            website functionality.
          </p>
          <p>
            We may use third-party analytics tools (such as Google Analytics) to understand how visitors interact with our
            site. These services have their own privacy policies governing data use.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">8. Children's Privacy</h2>
          <p>
            Our services are not directed to individuals under the age of 13. We do not knowingly collect personal
            information from children. If we become aware that we have inadvertently collected information from a child
            under 13, we will delete it promptly.
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">9. Contact Us</h2>
          <p>
            If you have questions, concerns, or requests regarding this Privacy Policy or your personal information,
            please contact us:
          </p>
          <p class="text-navy">
            Floyd's Plumbing LLC<br />
            4145 SE 47th Pl, Ocala, FL 34480<br />
            Phone: <a class="font-semibold text-brand underline underline-offset-2 hover:text-brand-dark" href="tel:+13523046404">(352) 304-6404</a><br />
            Email:{' '}
            <a class="font-semibold text-brand underline underline-offset-2 hover:text-brand-dark" href="mailto:kenny@floydtheplumber.com">kenny@floydtheplumber.com</a>
          </p>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-black uppercase tracking-tight text-navy sm:text-2xl">10. Changes to This Policy</h2>
          <p>
            We reserve the right to update this Privacy Policy at any time. When we make material changes, we will update
            the effective date at the top of this page. Continued use of our services after any changes constitutes
            acceptance of the updated policy.
          </p>
        </section>

        <p class="border-t border-slate-200 pt-8 text-sm text-slate-600">
          © 2026 Floyd's Plumbing LLC. All rights reserved.
        </p>
      </div>
    </div>
  </article>

  <BreadcrumbJsonLd crumbs={[{ name: 'Home', item: '/' }, { name: 'Privacy Policy', item: '/privacy/' }]} />
</BaseLayout>
