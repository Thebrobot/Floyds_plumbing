---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Privacy Policy | Floyd's Plumbing";
const description = "Privacy policy placeholder for Floyd's Plumbing.";
---

<BaseLayout {title} {description} noIndex>
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="font-display text-3xl uppercase text-navy">Privacy Policy</h1>
    <p class="mt-6 text-slate-600">
      This page is a placeholder. Replace with your attorney-approved privacy policy before collecting data online.
    </p>
  </div>
</BaseLayout>
