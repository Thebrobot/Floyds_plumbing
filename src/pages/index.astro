---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import PhotoCard from '../components/PhotoCard.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import Testimonials from '../components/Testimonials.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import SpecialOffers from '../components/SpecialOffers.astro';
import WaveDivider from '../components/WaveDivider.astro';
import StatsStrip from '../components/StatsStrip.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import FaqSection from '../components/FaqSection.astro';
import FinancingBanner from '../components/FinancingBanner.astro';
import FaqJsonLd from '../components/FaqJsonLd.astro';
import { siteConfig } from '../site.config';
import { mainServices } from '../data/services';
import { faqs } from '../data/faqs';

const title = "Ocala Plumbers | Floyd's Plumbing | Licensed, 24/7, Since 2008";
const description =
  "Ocala plumbers since 2008: 24/7 emergency service, water heaters, repipes, drain cleaning, backflow testing. Licensed, insured, family-owned. Upfront flat-rate pricing.";
---

<BaseLayout {title} {description} preloadHero>

  <!-- ===== 1. HERO ===== -->
  <section
    class="hero-home relative z-[1] flex min-h-[min(62vh,600px)] items-end overflow-hidden pb-14 sm:pb-16 md:min-h-[min(82vh,800px)] md:pb-14"
    aria-labelledby="hero-heading"
  >
    <img
      src={siteConfig.heroImagePath}
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-[78%_center] sm:object-[58%_center] lg:object-center"
      width="1024"
      height="576"
      sizes="100vw"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-navy/85 via-navy/55 to-navy/75 sm:bg-gradient-to-r sm:from-navy/88 sm:from-[-8%] sm:via-navy/60 sm:via-45% sm:to-navy/50"
      aria-hidden="true"
    ></div>

    <!-- Subtle water ripple rings -->
    <div class="hero-pulse-rings" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div
      class="relative z-10 mx-auto w-full max-w-7xl px-4 pb-8 pt-32 text-center sm:px-6 sm:pb-10 sm:pt-32 sm:text-left lg:px-8 [&_h1]:drop-shadow-[0_2px_20px_rgba(0,0,0,0.55)] [&_.hero-sub]:drop-shadow-[0_1px_12px_rgba(0,0,0,0.4)]"
    >
      <div class="mx-auto max-w-xl sm:mx-0">

        <!-- Rating badges -->
        <div class="mb-7 flex flex-wrap items-center justify-center gap-3 sm:justify-start sm:gap-4">
          <!-- Google badge -->
          <a
            href={siteConfig.googleBusinessUrl}
            class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-3 py-2 backdrop-blur-sm transition hover:bg-white/15"
            rel="noopener noreferrer"
            target="_blank"
            aria-label="See our Google reviews"
          >
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white" aria-hidden="true">
              <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </span>
            <div>
              <div class="flex gap-0.5" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="h-3.5 w-3.5 text-amber-400" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <p class="text-xs font-black uppercase tracking-wide text-white">{siteConfig.rating.value} ({siteConfig.rating.count}+)</p>
            </div>
          </a>
          <a
            href={siteConfig.googleBusinessUrl}
            class="inline-flex items-center justify-center rounded-full bg-yellow px-4 py-2 text-xs font-black uppercase tracking-wide text-navy shadow-md ring-2 ring-white/25 transition hover:bg-yellow-hover"
            rel="noopener noreferrer"
            target="_blank"
          >
            Leave a review
          </a>
          <!-- License badge -->
          <div class="flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-3 py-2 backdrop-blur-sm">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-yellow text-white" aria-hidden="true">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            </span>
            <div>
              <p class="text-[0.7rem] font-bold uppercase tracking-wide text-white/70">Florida Licensed</p>
              <p class="text-xs font-black uppercase tracking-wide text-white">{siteConfig.license.cfc}</p>
            </div>
          </div>
        </div>

        <!-- Headline -->
        <h1
          id="hero-heading"
          class="text-balance text-4xl font-black uppercase leading-[1.06] tracking-tight text-white sm:text-5xl md:text-6xl lg:text-[3.35rem] lg:leading-[1.05]"
        >
          Plumbing You Can Count On When It Matters Most
        </h1>

        <!-- Tagline box -->
        <div class="mt-8 w-full [transform:skewX(-10deg)] rounded-xl border-4 border-white bg-sky-200 px-5 py-3.5 shadow-lg sm:[transform:skewX(-15deg)] sm:px-8 sm:py-4">
          <p class="[transform:skewX(10deg)] text-center text-sm font-black italic uppercase leading-snug tracking-wide text-navy sm:[transform:skewX(15deg)] sm:text-left sm:text-lg">
            Honest Work. Fair Prices. <span class="text-red-600">No Surprises.</span>
          </p>
        </div>

        <!-- Trust items: centered pillars on mobile, horizontal row on desktop -->
        <div class="hero-sub mt-10 flex flex-row justify-center gap-x-6 sm:justify-start sm:gap-x-10 sm:gap-y-4 md:gap-x-12">
          <div class="flex flex-col items-center gap-1.5 text-white sm:flex-row sm:gap-3">
            <svg class="h-7 w-7 shrink-0 text-yellow drop-shadow-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              <path d="m9 12 2 2 4-4" />
            </svg>
            <span class="text-center text-[0.6rem] font-black uppercase leading-tight tracking-[0.08em] sm:text-left sm:text-sm sm:tracking-[0.12em]">Licensed &amp;<br class="sm:hidden" /> Insured</span>
          </div>
          <div class="flex flex-col items-center gap-1.5 text-white sm:flex-row sm:gap-3">
            <svg class="h-7 w-7 shrink-0 text-yellow drop-shadow-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 6v6l4 2" />
            </svg>
            <span class="text-center text-[0.6rem] font-black uppercase leading-tight tracking-[0.08em] sm:text-left sm:text-sm sm:tracking-[0.12em]">24/7<br class="sm:hidden" /> Emergency</span>
          </div>
          <div class="flex flex-col items-center gap-1.5 text-white sm:flex-row sm:gap-3">
            <svg class="h-7 w-7 shrink-0 text-yellow drop-shadow-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="8" r="6" />
              <path d="m8.21 13.89-1.94 7.11 5.73-3.26 5.73 3.26-1.94-7.11" />
            </svg>
            <span class="text-center text-[0.6rem] font-black uppercase leading-tight tracking-[0.08em] sm:text-left sm:text-sm sm:tracking-[0.12em]">Satisfaction<br class="sm:hidden" /> Guaranteed</span>
          </div>
        </div>

        <!-- CTA buttons: hidden on mobile, visible on sm+ -->
        <div class="mt-8 hidden sm:flex sm:flex-row sm:flex-wrap sm:items-center sm:gap-4">
          <a
            href={`tel:${siteConfig.phoneTel}`}
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-red-600 px-8 py-4 text-center text-sm font-black leading-snug tracking-wide text-white shadow-lg ring-1 ring-white/20 transition hover:bg-red-700 sm:w-auto sm:px-10 sm:text-base sm:leading-tight cta-phone-pulse"
            aria-label={`Call for 24/7 emergency plumbing at ${siteConfig.phoneDisplay}.`}
          >
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="normal-case">24/7 emergency: {siteConfig.phoneDisplay}</span>
          </a>
          <a
            href="/contact/"
            class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-white/25 bg-white px-10 py-4 text-center text-sm font-black uppercase tracking-[0.1em] text-navy shadow-lg transition hover:bg-brand-light sm:w-auto"
          >
            Book Online
          </a>
        </div>

      </div>
    </div>

    <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20" aria-hidden="true">
      <WaveDivider fill="hero" />
    </div>
  </section>

  <!-- ===== 2. STATS STRIP ===== -->
  <StatsStrip />

  <!-- ===== 3. POPULAR SERVICES ===== -->
  <section id="services" class="bg-page py-16 md:py-24" aria-labelledby="services-heading">
    <div class="reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">What We Do</p>
        <h2 id="services-heading" class="mt-2 text-3xl font-black uppercase tracking-tight text-navy sm:text-4xl">
          Ocala Plumbing Services
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base font-medium text-slate-600">
          From new construction to emergency repairs, we match the right crew to the job.
        </p>
      </div>

      <ul
        class="stagger mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 lg:auto-rows-[minmax(0,1fr)]"
      >
        {mainServices.slice(0, 7).map((s, i) => (
          <li
            class:list={[
              'min-w-0',
              i === 0 && 'sm:col-span-2 lg:col-span-2 lg:row-span-2',
              i === 5 && 'lg:col-span-2 lg:col-start-1 lg:row-start-3',
              i === 6 && 'lg:col-span-2 lg:col-start-3 lg:row-start-3',
            ]}
          >
            <a
              href={`/services/${s.slug}/`}
              class="card-service-photo group flex h-full min-h-[280px] flex-col overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-md transition-[transform,box-shadow] duration-200 lg:min-h-0"
            >
              <div
                class:list={[
                  'relative aspect-[3/2] w-full overflow-hidden bg-gradient-to-br from-brand/20 to-navy/30',
                  i === 0 ? 'lg:aspect-auto lg:min-h-[12rem] lg:flex-1' : 'shrink-0',
                ]}
              >
                {s.heroImage ? (
                  <img
                    src={s.heroImage}
                    alt={s.heroImageAlt ?? s.title}
                    width="820"
                    height="547"
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.05] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="absolute inset-0 bg-gradient-to-br from-brand/70 via-brand/60 to-navy" aria-hidden="true"></div>
                )}
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-navy/70 via-navy/15 to-transparent" aria-hidden="true"></div>
                <span
                  class:list={[
                    'absolute bottom-4 left-4 flex items-center justify-center rounded-full bg-yellow text-white shadow-lg ring-4 ring-white/90 transition-transform duration-200 group-hover:scale-105',
                    i === 0 ? 'h-14 w-14 lg:h-16 lg:w-16' : 'h-12 w-12',
                  ]}
                  aria-hidden="true"
                >
                  <ServiceIcon slug={s.slug} class={i === 0 ? 'h-7 w-7 lg:h-8 lg:w-8' : 'h-6 w-6'} />
                </span>
              </div>
              <div
                class:list={[
                  'flex flex-col',
                  i === 0 ? 'shrink-0 p-6 sm:p-7' : 'flex-1 p-6',
                ]}
              >
                <h3
                  class:list={[
                    'font-black uppercase tracking-tight text-navy',
                    i === 0 ? 'text-lg sm:text-xl' : 'text-lg',
                  ]}
                >
                  {s.title}
                </h3>
                <p
                  class:list={[
                    'mt-2 leading-relaxed text-slate-600',
                    i !== 0 && 'flex-1',
                    i === 0 ? 'text-sm sm:text-base' : 'text-sm',
                  ]}
                >
                  {s.shortDescription}
                </p>
                <span class="mt-4 text-sm font-bold text-brand transition group-hover:translate-x-0.5">
                  Learn more →
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-10 text-center">
        <a
          href="/services/"
          class="inline-flex items-center justify-center rounded-full border-2 border-brand px-8 py-3 text-sm font-black uppercase tracking-wide text-brand transition hover:bg-brand hover:text-white"
        >
          View All Services →
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 4. WHY CHOOSE US ===== -->
  <WhyChooseUs />

  <!-- ===== 5. ABOUT ===== -->
  <section id="about" class="bg-page-muted py-16 md:py-24" aria-labelledby="about-heading">
    <div class="reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
        <!-- Text -->
        <div>
          <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">Who We Are</p>
          <h2 id="about-heading" class="mt-2 text-3xl font-black uppercase tracking-tight text-navy sm:text-4xl">
            Your Local Ocala Plumbers Rooted in Tradition &amp; Excellence
          </h2>
          <p class="mt-6 text-base leading-relaxed text-slate-700">
            For over {new Date().getFullYear() - siteConfig.foundingYear} years, <strong class="text-navy">Floyd's Plumbing</strong> has been more than just a plumbing
            company; we're a trusted partner to homeowners and builders across Marion County. Founded in {siteConfig.foundingYear},
            we've built our reputation on honest work, fair pricing, and showing up when it matters most.
          </p>
          <p class="mt-4 text-base leading-relaxed text-slate-700">
            From custom new construction to emergency repairs, our family-owned crew treats every job like it's our own
            home. We're licensed, insured, and committed to doing the job right the first time: no shortcuts,
            no upsells, no surprises.
          </p>
          <ul class="mt-6 space-y-3 text-slate-700">
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow text-sm font-black text-white" aria-hidden="true">✓</span>
              <span><strong class="text-navy">Family-owned:</strong> local people who care about the community.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow text-sm font-black text-white" aria-hidden="true">✓</span>
              <span><strong class="text-navy">24/7 emergency service:</strong> we answer when others don't.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow text-sm font-black text-white" aria-hidden="true">✓</span>
              <span><strong class="text-navy">Transparent pricing:</strong> you'll always know the cost before we start.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow text-sm font-black text-white" aria-hidden="true">✓</span>
              <span><strong class="text-navy">Florida CFC licensed:</strong> {siteConfig.license.cfc}, bonded &amp; insured.</span>
            </li>
          </ul>
          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a
              href="/about/"
              class="inline-flex items-center justify-center rounded-full bg-navy px-8 py-3.5 text-sm font-black uppercase tracking-wide text-white shadow-sm transition hover:bg-charcoal-dark"
            >
              Meet Our Team
            </a>
            <a
              href="/contact/"
              class="inline-flex items-center justify-center rounded-full bg-yellow px-8 py-3.5 text-sm font-black uppercase tracking-wide text-white shadow-sm transition hover:bg-yellow-hover"
            >
              Request Service
            </a>
          </div>
        </div>

        <!-- Image -->
        <PhotoCard
          src="/images/floyds-service-van.webp"
          alt="Floyd's Plumbing branded service van serving Ocala and Marion County"
          minClass="min-h-[300px] sm:min-h-[420px]"
        />
      </div>
    </div>
  </section>

  <!-- ===== 6. SPECIAL OFFERS ===== -->
  <SpecialOffers />

  <!-- ===== 7. FINANCING ===== -->
  <FinancingBanner />

  <!-- ===== 8. TESTIMONIALS ===== -->
  <Testimonials />

  <!-- ===== 9. FAQ ===== -->
  <FaqSection limit={5} />

  <!-- ===== 10. SERVICE AREAS ===== -->
  <ServiceAreas />

  <!-- ===== 11. CONTACT FORM ===== -->
  <section id="contact" class="bg-page py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">Get in Touch</p>
          <h2 class="mt-2 text-3xl font-black uppercase tracking-tight text-navy sm:text-4xl">Ready When You Are</h2>
          <p class="mt-4 text-base leading-relaxed text-slate-600">
            Prefer voice? Call <a class="font-bold text-red-600 hover:text-red-700 hover:underline" href={`tel:${siteConfig.phoneTel}`}>{siteConfig.phoneDisplay}</a> for scheduling.
            For project details, use the form; we read every message.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a
              href={`tel:${siteConfig.phoneTel}`}
              class="inline-flex items-center justify-center rounded-full bg-red-600 px-6 py-3 text-sm font-bold text-white hover:bg-red-700"
            >
              Call {siteConfig.phoneDisplay}
            </a>
            <a
              href="/contact/"
              class="inline-flex items-center justify-center rounded-full bg-yellow px-6 py-3 text-sm font-black uppercase tracking-wide text-white shadow-sm hover:bg-yellow-hover"
            >
              Full Contact Page
            </a>
          </div>
          <div class="mt-10 space-y-4 rounded-2xl border border-slate-200 bg-page-muted p-6">
            <p class="text-xs font-black uppercase tracking-widest text-brand">Our Promise</p>
            <ul class="space-y-2 text-sm text-slate-700">
              <li class="flex gap-2"><span class="text-yellow">✓</span> Same-day response on most calls</li>
              <li class="flex gap-2"><span class="text-yellow">✓</span> Flat-rate pricing in writing before work begins</li>
              <li class="flex gap-2"><span class="text-yellow">✓</span> {siteConfig.guarantee.laborWarrantyMonths}-month labor warranty on every repair</li>
              <li class="flex gap-2"><span class="text-yellow">✓</span> Clean, respectful technicians in uniform</li>
            </ul>
          </div>
        </div>
        <ContactForm id="home-contact" compact heading="Quick Request" />
      </div>
    </div>
  </section>

  <FaqJsonLd items={faqs} />
</BaseLayout>
