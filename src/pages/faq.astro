---
import BaseLayout from '../layouts/BaseLayout.astro';
import FaqSection from '../components/FaqSection.astro';
import BreadcrumbJsonLd from '../components/BreadcrumbJsonLd.astro';
import FaqJsonLd from '../components/FaqJsonLd.astro';
import { siteConfig } from '../site.config';
import { faqs } from '../data/faqs';

const title = "FAQ | Floyd's Plumbing Ocala";
const description =
  "Answers to common questions about licensing, pricing, warranties, service area, emergency response, backflow testing, and more. Floyd's Plumbing Ocala.";
---

<BaseLayout {title} {description}>
  <div class="relative border-b border-slate-200/80 bg-hero">
    <div class="bg-ripple pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
      <nav class="text-sm font-semibold text-brand-dark" aria-label="Breadcrumb">
        <ol class="flex flex-wrap gap-2">
          <li><a class="underline decoration-brand/30 underline-offset-4 hover:text-brand" href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="font-bold text-navy">FAQ</li>
        </ol>
      </nav>
      <h1 class="font-display mt-6 text-4xl uppercase text-navy sm:text-5xl">Frequently Asked Questions</h1>
      <p class="mt-4 max-w-2xl text-lg font-medium text-slate-700">
        Everything you've wanted to ask a plumber but weren't sure how to, answered straight.
      </p>
    </div>
  </div>

  <FaqSection eyebrow="Every Question Answered" heading="" showViewAll={false} />

  <section class="bg-page py-14">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black uppercase tracking-tight text-navy">Still have a question?</h2>
      <p class="mt-3 text-slate-600">
        Give us a call. We'd rather spend five minutes on the phone with you than sell you something you don't need.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={`tel:${siteConfig.phoneTel}`}
          class="inline-flex items-center justify-center rounded-full bg-red-600 px-8 py-3.5 text-sm font-black uppercase tracking-wide text-white shadow-md hover:bg-red-700"
        >
          Call {siteConfig.phoneDisplay}
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-full bg-navy px-8 py-3.5 text-sm font-black uppercase tracking-wide text-white shadow-md hover:bg-charcoal-dark"
        >
          Send a Message
        </a>
      </div>
    </div>
  </section>

  <BreadcrumbJsonLd crumbs={[{ name: 'Home', item: '/' }, { name: 'FAQ', item: '/faq/' }]} />
  <FaqJsonLd items={faqs} />
</BaseLayout>
