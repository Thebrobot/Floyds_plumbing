---
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import BreadcrumbJsonLd from '../../components/BreadcrumbJsonLd.astro';
import ServiceIcon from '../../components/ServiceIcon.astro';
import { services, getServiceBySlug } from '../../data/services';
import { siteConfig } from '../../site.config';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = getServiceBySlug(slug ?? '');

if (!service) {
  return Astro.redirect('/services/');
}

const title = `${service.title} | Floyd's Plumbing Ocala`;
const description = service.metaDescription;

const relatedServices = (service.related ?? [])
  .map((s) => getServiceBySlug(s))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
---

<ServiceLayout
  title={title}
  description={description}
  heading={service.title}
  heroImage={service.heroImage}
  heroImageAlt={service.heroImageAlt}
>
  <p class="!text-lg font-semibold text-navy sm:!text-xl">{service.shortDescription}</p>
  {service.paragraphs.map((p) => <p>{p}</p>)}
  <h2 class="font-display !mt-10 text-xl uppercase text-navy">What we handle</h2>
  <ul class="list-none space-y-3 pl-0">
    {
      service.checklist.map((item) => (
        <li class="flex gap-3 text-slate-800">
          <span
            class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow text-xs font-black text-white"
            aria-hidden="true">✓</span
          >
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <div class="!mt-12 rounded-2xl border border-brand/30 bg-brand-light p-6 sm:p-8">
    <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">Ready to schedule?</p>
    <h2 class="!mt-2 text-2xl font-black uppercase text-navy">Request a quote for {service.title.toLowerCase()}.</h2>
    <p class="!mt-3 text-base text-slate-700">
      Flat-rate pricing, same-day response where possible, and a 12-month labor warranty on every job.
    </p>
    <div class="!mt-6 flex flex-col gap-3 sm:flex-row">
      <a
        href={`/contact/?service=${service.slug}`}
        class="inline-flex items-center justify-center rounded-full bg-yellow px-7 py-3 text-sm font-black uppercase tracking-wide text-white shadow-sm transition hover:bg-yellow-hover"
      >
        Request This Service
      </a>
      <a
        href={`tel:${siteConfig.phoneTel}`}
        class="inline-flex items-center justify-center rounded-full bg-red-600 px-7 py-3 text-sm font-black uppercase tracking-wide text-white shadow-sm transition hover:bg-red-700"
      >
        Call {siteConfig.phoneDisplay}
      </a>
    </div>
  </div>

  {relatedServices.length > 0 && (
    <div class="!mt-14">
      <h2 class="font-display !mt-0 text-xl uppercase text-navy">You may also need</h2>
      <ul class="!mt-5 grid list-none gap-4 pl-0 sm:grid-cols-3">
        {relatedServices.map((r) => (
          <li>
            <a
              href={`/services/${r.slug}/`}
              class="group flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-brand hover:shadow-md motion-reduce:transform-none"
            >
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-brand/10 text-brand">
                <ServiceIcon slug={r.slug as any} class="h-4 w-4" />
              </span>
              <p class="mt-3 text-sm font-black uppercase tracking-tight text-navy group-hover:text-brand">{r.navTitle ?? r.title}</p>
              <span class="mt-2 text-xs font-bold text-brand">View →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <BreadcrumbJsonLd
    crumbs={[
      { name: 'Home', item: '/' },
      { name: 'Services', item: '/services/' },
      { name: service.title, item: `/services/${service.slug}/` }
    ]}
  />
</ServiceLayout>
