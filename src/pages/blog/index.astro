---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbJsonLd from '../../components/BreadcrumbJsonLd.astro';
import { posts } from '../../data/blog';

const title = "Plumbing Tips & Guides | Floyd's Plumbing Blog";
const description =
  "Straight-talk plumbing advice for Ocala homeowners and businesses. Shut-off guides, repipe warning signs, hard water, backflow testing, and more.";

const sorted = [...posts].sort((a, b) => (a.publishedAt < b.publishedAt ? 1 : -1));
---

<BaseLayout {title} {description}>
  <div class="relative border-b border-slate-200/80 bg-hero">
    <div class="bg-ripple pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
      <nav class="text-sm font-semibold text-brand-dark" aria-label="Breadcrumb">
        <ol class="flex flex-wrap gap-2">
          <li><a class="underline decoration-brand/30 underline-offset-4 hover:text-brand" href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="font-bold text-navy">Blog</li>
        </ol>
      </nav>
      <h1 class="font-display mt-6 text-4xl uppercase text-navy sm:text-5xl">Plumbing Tips &amp; Guides</h1>
      <p class="mt-4 max-w-2xl text-lg font-medium text-slate-700">
        Real advice from a real crew. No gimmicks, no filler, no selling you something you don't need.
      </p>
    </div>
  </div>

  <div class="reveal mx-auto max-w-5xl px-4 py-14 sm:px-6 lg:px-8">
    <ul class="space-y-5">
      {sorted.map((p) => (
        <li>
          <a href={`/blog/${p.slug}/`} class="group block rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-brand hover:shadow-lg motion-reduce:transform-none">
            <div class="flex items-center gap-3 text-xs font-bold uppercase tracking-widest text-slate-500">
              <time datetime={p.publishedAt}>{new Date(p.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span aria-hidden="true">·</span>
              <span>{p.readMinutes} min read</span>
            </div>
            <h2 class="mt-2 text-xl font-black uppercase tracking-tight text-navy group-hover:text-brand sm:text-2xl">{p.title}</h2>
            <p class="mt-3 text-slate-600">{p.description}</p>
            <span class="mt-4 inline-flex text-sm font-bold text-brand transition group-hover:translate-x-0.5">Read article →</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <BreadcrumbJsonLd crumbs={[{ name: 'Home', item: '/' }, { name: 'Blog', item: '/blog/' }]} />
</BaseLayout>
