---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { mainServices } from '../data/services';

const title = "Page Not Found | Floyd's Plumbing";
const description = "The page you're looking for has moved or does not exist.";
---

<BaseLayout {title} {description} noIndex>
  <section class="relative overflow-hidden bg-hero">
    <div class="bg-ripple pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl px-4 py-24 text-center sm:px-6 sm:py-32 lg:px-8">
      <p class="text-sm font-black uppercase tracking-[0.25em] text-brand">Error 404</p>
      <h1 class="mt-3 text-balance text-5xl font-black uppercase tracking-tight text-navy sm:text-6xl">
        We couldn't find that page
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-slate-700">
        It might have moved, or the link might be outdated. Try one of the options below, or call us and we'll point
        you in the right direction.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-full bg-navy px-8 py-3.5 text-sm font-black uppercase tracking-wide text-white shadow-sm transition hover:bg-charcoal-dark"
        >
          Back to Home
        </a>
        <a
          href={`tel:${siteConfig.phoneTel}`}
          class="inline-flex items-center justify-center rounded-full bg-red-600 px-8 py-3.5 text-sm font-black uppercase tracking-wide text-white shadow-sm transition hover:bg-red-700"
        >
          Call {siteConfig.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <section class="bg-page py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-xl font-black uppercase tracking-tight text-navy">Popular pages</h2>
      <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {mainServices.map((s) => (
          <li>
            <a
              href={`/services/${s.slug}/`}
              class="block rounded-2xl border border-slate-200 bg-white p-4 text-sm font-bold text-navy shadow-sm transition hover:border-brand hover:text-brand"
            >
              {s.title}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/contact/"
            class="block rounded-2xl border border-slate-200 bg-white p-4 text-sm font-bold text-navy shadow-sm transition hover:border-brand hover:text-brand"
          >
            Request Service
          </a>
        </li>
        <li>
          <a
            href="/service-areas/"
            class="block rounded-2xl border border-slate-200 bg-white p-4 text-sm font-bold text-navy shadow-sm transition hover:border-brand hover:text-brand"
          >
            Service Areas
          </a>
        </li>
        <li>
          <a
            href="/faq/"
            class="block rounded-2xl border border-slate-200 bg-white p-4 text-sm font-bold text-navy shadow-sm transition hover:border-brand hover:text-brand"
          >
            Frequently Asked Questions
          </a>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
