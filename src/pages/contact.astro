---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import BreadcrumbJsonLd from '../components/BreadcrumbJsonLd.astro';
import { siteConfig } from '../site.config';

const serviceParam = Astro.url.searchParams.get('service');
const defaultService = serviceParam ?? '';

const title = "Contact Floyd's Plumbing | Ocala Plumbers";
const description =
  "Request Ocala plumbing service: new construction, residential, commercial, repairs, backflow testing, remodels and repipes. Call or message Floyd's Plumbing.";

const mapEmbedUrl = `https://www.google.com/maps?q=${siteConfig.serviceGeo.latitude},${siteConfig.serviceGeo.longitude}&z=11&output=embed`;
---

<BaseLayout {title} {description}>
  <div class="relative border-b border-slate-200/80 bg-hero">
    <div class="bg-ripple pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
      <nav class="text-sm font-semibold text-brand-dark" aria-label="Breadcrumb">
        <ol class="flex flex-wrap gap-2">
          <li><a class="underline decoration-brand/30 underline-offset-4 hover:text-brand" href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="font-bold text-navy">Contact</li>
        </ol>
      </nav>
      <h1 class="font-display mt-6 text-4xl uppercase text-navy sm:text-5xl">Contact</h1>
      <p class="mt-4 max-w-2xl text-lg font-medium text-slate-700">
        Tell us what you need. Include photos or plans if helpful. We respond as quickly as dispatch allows.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a
          href={`tel:${siteConfig.phoneTel}`}
          class="inline-flex items-center justify-center gap-2.5 rounded-full bg-red-600 px-6 py-3.5 text-base font-black text-white shadow-md transition hover:bg-red-700"
        >
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {siteConfig.phoneDisplay}
        </a>
        <a
          href={`mailto:${siteConfig.email}`}
          class="inline-flex items-center justify-center gap-2.5 rounded-full border-2 border-navy bg-white px-6 py-3.5 text-base font-black text-navy shadow-sm transition hover:bg-page-muted"
        >
          Email {siteConfig.email}
        </a>
      </div>
    </div>
  </div>

  <div class="reveal mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-5 lg:gap-12">
      <div class="lg:col-span-3">
        <ContactForm id="contact-page" heading="Service request" defaultService={defaultService} />
      </div>
      <aside class="space-y-6 lg:col-span-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-sm font-black uppercase tracking-widest text-brand">How to reach us</h2>
          <ul class="mt-5 space-y-4 text-slate-700">
            <li class="flex items-start gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-red-50 text-red-600">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Phone</p>
                <a href={`tel:${siteConfig.phoneTel}`} class="text-base font-black text-navy hover:text-brand">{siteConfig.phoneDisplay}</a>
                <p class="text-xs text-slate-500">Call for emergencies 24/7</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand/10 text-brand">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Email</p>
                <a href={`mailto:${siteConfig.email}`} class="text-base font-bold text-navy hover:text-brand">{siteConfig.email}</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-yellow/15 text-yellow">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M12 6v6l4 2" />
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Hours</p>
                {siteConfig.hours.map((h) => (
                  <p class="text-sm font-bold text-navy">
                    {h.days[0]}{h.days.length > 1 ? `–${h.days[h.days.length - 1]}` : ''}: {h.opens} – {h.closes}
                  </p>
                ))}
                {siteConfig.emergency24_7 && (
                  <p class="mt-1 text-sm font-black uppercase tracking-wide text-red-600">Emergencies 24/7</p>
                )}
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-700">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M12 2s8 7 8 12a8 8 0 11-16 0c0-5 8-12 8-12z" />
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-slate-500">Service area</p>
                <p class="text-sm text-slate-600">Ocala, FL &amp; all of Marion County within ~20 miles.</p>
                <a href="/service-areas/" class="mt-1 inline-block text-sm font-bold text-brand hover:underline">View all areas →</a>
              </div>
            </li>
          </ul>
        </div>

        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
          <iframe
            src={mapEmbedUrl}
            title="Floyd's Plumbing service area map"
            width="100%"
            height="320"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
          <div class="p-4 text-center">
            <p class="text-sm font-bold text-navy">Based in Ocala, FL</p>
            <p class="text-xs text-slate-500">Serving Marion County &amp; surrounding areas</p>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <BreadcrumbJsonLd crumbs={[{ name: 'Home', item: '/' }, { name: 'Contact', item: '/contact/' }]} />
</BaseLayout>
