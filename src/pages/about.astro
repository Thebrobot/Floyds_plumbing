---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoCard from '../components/PhotoCard.astro';
import BreadcrumbJsonLd from '../components/BreadcrumbJsonLd.astro';
import { siteConfig } from '../site.config';

const title = "About Floyd's Plumbing | Family-Owned Ocala Plumbers Since 2008";
const description =
  "Meet Floyd's Plumbing: Ocala's family-owned, Florida CFC-licensed plumbers since 2008. Our founding story, our crew, and the standard of work we believe in.";

const yearsInBusiness = new Date().getFullYear() - siteConfig.foundingYear;
---

<BaseLayout {title} {description}>
  <div class="relative border-b border-slate-200/80 bg-hero">
    <div class="bg-ripple pointer-events-none absolute inset-0 opacity-70" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
      <nav class="text-sm font-semibold text-brand-dark" aria-label="Breadcrumb">
        <ol class="flex flex-wrap gap-2">
          <li><a class="underline decoration-brand/30 underline-offset-4 hover:text-brand" href="/">Home</a></li>
          <li aria-hidden="true">/</li>
          <li class="font-bold text-navy">About</li>
        </ol>
      </nav>
      <h1 class="font-display mt-6 text-4xl uppercase text-navy sm:text-5xl">About Us</h1>
      <p class="mt-4 max-w-2xl text-lg font-medium text-slate-700">
        A great group of guys, old-school values, and a standard of work we still believe in.
      </p>
    </div>
  </div>

  <section class="bg-page py-14">
    <div class="reveal mx-auto grid max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-5 lg:gap-16 lg:px-8">
      <div class="lg:col-span-3">
        <h2 class="text-2xl font-black uppercase tracking-tight text-navy sm:text-3xl">Our story</h2>
        <div class="mt-6 space-y-5 text-base leading-relaxed text-slate-700">
          <p>
            {siteConfig.businessName} started in <strong class="text-navy">{siteConfig.foundingYear}</strong> with a simple idea: show up on time,
            tell the truth, and leave the job cleaner than we found it. Ocala was growing, tract work was everywhere, and we
            wanted to be the crew you called when the job required patience: custom homes, tricky remodels, and commercial
            kitchens that can't afford downtime.
          </p>
          <p>
            Our founding story isn't about flash; it's about reputation earned one wrench turn at a time. Family-owned means
            we answer for our name on the side of the truck. When you invite us in, you get experienced plumbers who respect
            your home, your customers, and your timeline.
          </p>
          <p>
            Today we're still a <strong class="text-navy">great group of guys</strong> who take pride in workmanship. If you are
            in Ocala, Stone Creek, Colessa, or anywhere in our Marion County service area, we'd be proud to earn your business.
          </p>
        </div>
      </div>
      <aside class="lg:col-span-2">
        <PhotoCard
          src="/images/pipes-detail.jpg"
          alt="Copper and PEX plumbing lines in a residential installation"
          minClass="min-h-[280px] sm:min-h-[360px]"
        />
      </aside>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="bg-navy py-12 text-white md:py-14">
    <div class="reveal mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <ul class="grid grid-cols-2 gap-6 text-center sm:grid-cols-4">
        <li>
          <p class="text-4xl font-black leading-none text-yellow sm:text-5xl">
            <span data-count-target={yearsInBusiness} data-count-duration="1400" data-count-decimals="0">0</span>+
          </p>
          <p class="mt-2 text-xs font-black uppercase tracking-widest text-slate-300">Years Serving Ocala</p>
        </li>
        <li>
          <p class="text-4xl font-black leading-none text-yellow sm:text-5xl">
            <span data-count-target={siteConfig.rating.count} data-count-duration="1400" data-count-decimals="0">0</span>+
          </p>
          <p class="mt-2 text-xs font-black uppercase tracking-widest text-slate-300">5-Star Reviews</p>
        </li>
        <li>
          <p class="text-4xl font-black leading-none text-yellow sm:text-5xl">
            <span data-count-target={siteConfig.rating.value} data-count-duration="1400" data-count-decimals="1">0</span>★
          </p>
          <p class="mt-2 text-xs font-black uppercase tracking-widest text-slate-300">Average Rating</p>
        </li>
        <li>
          <p class="text-4xl font-black leading-none text-yellow sm:text-5xl">24/7</p>
          <p class="mt-2 text-xs font-black uppercase tracking-widest text-slate-300">Emergency Response</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Credentials -->
  <section class="bg-page-muted py-14">
    <div class="reveal mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">Credentials</p>
        <h2 class="mt-2 text-2xl font-black uppercase tracking-tight text-navy sm:text-3xl">Licensed. Insured. Committed.</h2>
      </div>
      <ul class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <li class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand/10 text-brand">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              <path d="m9 12 2 2 4-4" />
            </svg>
          </div>
          <p class="mt-4 text-xs font-bold uppercase tracking-widest text-slate-500">License</p>
          <p class="mt-1 font-black text-navy">{siteConfig.license.cfc}</p>
          <p class="text-xs text-slate-500">Florida CFC</p>
        </li>
        <li class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand/10 text-brand">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6L9 17l-5-5" />
            </svg>
          </div>
          <p class="mt-4 text-xs font-bold uppercase tracking-widest text-slate-500">Insurance</p>
          <p class="mt-1 font-black text-navy">General + Liability</p>
          <p class="text-xs text-slate-500">Every truck, every crew</p>
        </li>
        <li class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand/10 text-brand">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="8" r="6" />
              <path d="m8.21 13.89-1.94 7.11 5.73-3.26 5.73 3.26-1.94-7.11" />
            </svg>
          </div>
          <p class="mt-4 text-xs font-bold uppercase tracking-widest text-slate-500">Warranty</p>
          <p class="mt-1 font-black text-navy">{siteConfig.guarantee.laborWarrantyMonths}-Month Labor</p>
          <p class="text-xs text-slate-500">{siteConfig.guarantee.satisfaction}</p>
        </li>
        <li class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-brand/10 text-brand">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
          </div>
          <p class="mt-4 text-xs font-bold uppercase tracking-widest text-slate-500">Community</p>
          <p class="mt-1 font-black text-navy">Family-Owned</p>
          <p class="text-xs text-slate-500">Since {siteConfig.foundingYear}</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Values / Promises -->
  <section class="bg-page py-14">
    <div class="reveal mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-xs font-black uppercase tracking-[0.25em] text-brand">How We Work</p>
        <h2 class="mt-2 text-2xl font-black uppercase tracking-tight text-navy sm:text-3xl">Our Customer Promise</h2>
      </div>
      <ul class="mt-10 grid gap-5 sm:grid-cols-2">
        <li class="flex gap-4 rounded-2xl border border-slate-200 bg-page-muted p-6">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow text-lg font-black text-white">1</span>
          <div>
            <h3 class="font-black text-navy">On-Time Arrival</h3>
            <p class="mt-1 text-sm text-slate-600">We give you a real window and we hit it. If we're running late, we call, not the other way around.</p>
          </div>
        </li>
        <li class="flex gap-4 rounded-2xl border border-slate-200 bg-page-muted p-6">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow text-lg font-black text-white">2</span>
          <div>
            <h3 class="font-black text-navy">Flat-Rate Pricing</h3>
            <p class="mt-1 text-sm text-slate-600">You get the full price in writing before any work starts. No clock-watching. No surprise fees.</p>
          </div>
        </li>
        <li class="flex gap-4 rounded-2xl border border-slate-200 bg-page-muted p-6">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow text-lg font-black text-white">3</span>
          <div>
            <h3 class="font-black text-navy">Clean Worksite</h3>
            <p class="mt-1 text-sm text-slate-600">Boot covers, drop cloths, and shop vacs. We leave your home the way we found it, or better.</p>
          </div>
        </li>
        <li class="flex gap-4 rounded-2xl border border-slate-200 bg-page-muted p-6">
          <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-yellow text-lg font-black text-white">4</span>
          <div>
            <h3 class="font-black text-navy">Honest Diagnosis</h3>
            <p class="mt-1 text-sm text-slate-600">If a repair is the right answer, we repair. If a replacement is smarter, we explain why. Never the other way around.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-page-muted py-12">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-black uppercase tracking-tight text-navy">Ready to work with us?</h2>
      <p class="mt-3 text-slate-600">Call, or send us a quick message and we'll get back to you the same day.</p>
      <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={`tel:${siteConfig.phoneTel}`} class="inline-flex items-center justify-center rounded-full bg-red-600 px-7 py-3 text-sm font-black uppercase tracking-wide text-white shadow-sm hover:bg-red-700">
          Call {siteConfig.phoneDisplay}
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center rounded-full bg-navy px-7 py-3 text-sm font-black uppercase tracking-wide text-white shadow-sm hover:bg-charcoal-dark">
          Request Service
        </a>
      </div>
    </div>
  </section>

  <BreadcrumbJsonLd crumbs={[{ name: 'Home', item: '/' }, { name: 'About', item: '/about/' }]} />
</BaseLayout>
